{
  "$schema": "https://schema.tauri.app/capabilities/2",
  "identifier": "default",
  "description": "Default capabilities for the AllMyStuff GUI (the main window and every per-machine console, terminal and files window)",
  "windows": [
    "main",
    "console-*",
    "terminal-*",
    "files-*"
  ],
  "permissions": [
    "core:default",
    "core:window:allow-set-title",
    "core:window:allow-close",
    "core:window:allow-destroy",
    "shell:allow-open",
    "dialog:default",
    "clipboard-manager:allow-read-text",
    "clipboard-manager:allow-write-text"
  ]
}
