{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AllMyStuff",
  "identifier": "works.allmystuff.gui",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1430",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "AllMyStuff",
        "width": 1180,
        "height": 760,
        "minWidth": 720,
        "minHeight": 480,
        "resizable": true,
        "fullscreen": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "AllMyStuff",
    "copyright": "Copyright © 2026 AllMyStuff",
    "category": "Utility",
    "shortDescription": "Your own computers, meshed together.",
    "longDescription": "AllMyStuff is a personal mesh for your own machines — remote desktop, screen and file sharing, and CEC remote support, peer-to-peer over your MyOwnMesh network.",
    "externalBin": ["binaries/myownmesh", "binaries/allmystuff-serve"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "-"
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
